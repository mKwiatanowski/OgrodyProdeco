---
import Icon from "./Icon.astro";
import { url } from "../lib/url";

interface Props {
  title: string;
  subtitle: string;
  primaryCtaLabel?: string;
  primaryCtaHref?: string;
  secondaryCtaLabel?: string;
  secondaryCtaHref?: string;
  image?: string;
  imageAlt?: string;
}
const {
  title,
  subtitle,
  primaryCtaLabel = "Zamów bezpłatną wycenę",
  primaryCtaHref = "/kontakt",
  secondaryCtaLabel = "Zobacz nasze realizacje",
  secondaryCtaHref = "/realizacje",
  image = "/images/hero/hero-ogrod.svg",
  imageAlt = "Zaprojektowany ogród ze ścieżką, rabatami i drzewami",
} = Astro.props;
---

<section class="relative isolate overflow-hidden">
  <img
    src={url(image)}
    alt={imageAlt}
    class="absolute inset-0 -z-10 h-full w-full object-cover"
  />
  <div class="absolute inset-0 -z-10 bg-gradient-to-r from-earth-900/75 via-earth-900/45 to-earth-900/10"></div>

  <div class="mx-auto max-w-6xl px-4 py-24 md:py-36 lg:py-44">
    <div class="max-w-2xl fade-up">
      <p class="mb-4 inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-1.5 text-sm font-medium text-brand-100 ring-1 ring-white/25 backdrop-blur">
        <Icon name="sprout" class="h-4 w-4" />
        Sanok i Podkarpacie · od 2011 roku
      </p>
      <h1 class="text-4xl md:text-6xl font-semibold text-white leading-tight text-balance">
        {title}
      </h1>
      <p class="mt-6 text-lg md:text-xl text-earth-50/95 max-w-xl">
        {subtitle}
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href={url(primaryCtaHref)}
          class="rounded-full bg-brand-500 px-7 py-3.5 font-semibold text-white shadow-lg shadow-brand-900/30 hover:bg-brand-400 transition-colors"
        >
          {primaryCtaLabel}
        </a>
        <a
          href={url(secondaryCtaHref)}
          class="rounded-full border border-white/40 bg-white/10 px-7 py-3.5 font-semibold text-white backdrop-blur hover:bg-white/20 transition-colors"
        >
          {secondaryCtaLabel}
        </a>
      </div>
    </div>
  </div>
</section>
