---
import Icon from "./Icon.astro";
const year = new Date().getFullYear();

const oferta = [
  { href: "/oferta/projektowanie-ogrodow", label: "Projektowanie ogrodów" },
  { href: "/oferta/nawierzchnie-i-podjazdy", label: "Nawierzchnie i podjazdy" },
  { href: "/oferta/mala-architektura", label: "Mała architektura" },
  { href: "/oferta/oswietlenie-ogrodowe", label: "Oświetlenie ogrodowe" },
  { href: "/oferta/pielegnacja-zielen", label: "Pielęgnacja zieleni" },
];
---

<footer class="bg-earth-900 text-earth-100 mt-24">
  <div class="mx-auto max-w-6xl px-4 py-14 grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
    <div>
      <p class="font-display text-2xl text-white mb-1">PRODECO</p>
      <p class="text-sm text-brand-300 mb-4">mamy rękę do ogrodu</p>
      <p class="text-sm text-earth-200 leading-relaxed">
        Projektowanie i realizacja ogrodów, nawierzchni i&nbsp;zieleni.
        Sanok i&nbsp;województwo podkarpackie, od&nbsp;2011&nbsp;roku.
      </p>
      <div class="mt-5 flex gap-3">
        <a
          href="https://www.facebook.com/Ogrodyprodeco"
          class="rounded-full bg-white/10 p-2.5 hover:bg-white/20 transition-colors"
          aria-label="Facebook — Ogrodyprodeco"
          rel="noopener"
        >
          <Icon name="facebook" class="h-5 w-5" />
        </a>
        <a
          href="https://www.instagram.com/ogrody_z_prodeco/"
          class="rounded-full bg-white/10 p-2.5 hover:bg-white/20 transition-colors"
          aria-label="Instagram — ogrody_z_prodeco"
          rel="noopener"
        >
          <Icon name="instagram" class="h-5 w-5" />
        </a>
      </div>
    </div>

    <div>
      <p class="font-semibold text-white mb-4">Oferta</p>
      <ul class="space-y-2 text-sm text-earth-200">
        {oferta.map((item) => (
          <li>
            <a href={item.href} class="hover:text-white transition-colors">{item.label}</a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <p class="font-semibold text-white mb-4">Na skróty</p>
      <ul class="space-y-2 text-sm text-earth-200">
        <li><a href="/o-nas" class="hover:text-white transition-colors">O nas</a></li>
        <li><a href="/realizacje" class="hover:text-white transition-colors">Realizacje</a></li>
        <li><a href="/kontakt" class="hover:text-white transition-colors">Kontakt</a></li>
        <li><a href="/kontakt" class="hover:text-white transition-colors">Bezpłatna wycena</a></li>
      </ul>
    </div>

    <div>
      <p class="font-semibold text-white mb-4">Kontakt</p>
      <ul class="space-y-3 text-sm text-earth-200">
        <li class="flex gap-2.5">
          <Icon name="map-pin" class="h-4 w-4 mt-0.5 shrink-0 text-brand-300" />
          <span>ul. Szopena 10/105<br />38-500 Sanok</span>
        </li>
        <li class="flex gap-2.5">
          <Icon name="phone" class="h-4 w-4 mt-0.5 shrink-0 text-brand-300" />
          <span>
            <a href="tel:+48608354401" class="hover:text-white">608 354 401</a> — Beata Bach<br />
            <a href="tel:+48793751983" class="hover:text-white">793 751 983</a> — Dawid Bach
          </span>
        </li>
        <li class="flex gap-2.5">
          <Icon name="mail" class="h-4 w-4 mt-0.5 shrink-0 text-brand-300" />
          <a href="mailto:kontakt@ogrodyprodeco.pl" class="hover:text-white">kontakt@ogrodyprodeco.pl</a>
        </li>
        <li class="flex gap-2.5">
          <Icon name="clock" class="h-4 w-4 mt-0.5 shrink-0 text-brand-300" />
          <span>pon–pt 8:00–17:00</span>
        </li>
      </ul>
    </div>
  </div>
  <div class="border-t border-earth-800 py-5 text-center text-xs text-earth-200/70">
    © {year} PRODECO Beata Bach · NIP 687-181-61-91 · Wszystkie prawa zastrzeżone
  </div>
</footer>
