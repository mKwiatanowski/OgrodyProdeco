---
import Icon from "./Icon.astro";

interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
}
const { title, description, href, icon } = Astro.props;
---

<a
  href={href}
  class="group flex flex-col rounded-2xl border border-brand-100 bg-white p-7 transition-all hover:-translate-y-1 hover:border-brand-300 hover:shadow-xl hover:shadow-brand-900/5"
>
  {icon && (
    <span class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-brand-50 text-brand-600 transition-colors group-hover:bg-brand-600 group-hover:text-white">
      <Icon name={icon} class="h-6 w-6" />
    </span>
  )}
  <h3 class="font-display text-xl text-earth-900 mb-2">{title}</h3>
  <p class="text-sm text-earth-700 leading-relaxed flex-1">{description}</p>
  <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600 group-hover:gap-3 transition-all">
    Zobacz szczegóły
    <Icon name="arrow-right" class="h-4 w-4" />
  </span>
</a>
