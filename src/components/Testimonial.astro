---
interface Props {
  autor: string;
  ocena: number;
}
const { autor, ocena } = Astro.props;
---

<figure class="flex flex-col rounded-2xl border border-brand-100 bg-white p-7 shadow-sm">
  <div class="mb-3 flex gap-0.5 text-brand-500" role="img" aria-label={`Ocena ${ocena} na 5`}>
    {Array.from({ length: 5 }).map((_, i) => (
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill={i < ocena ? "currentColor" : "none"} stroke="currentColor" stroke-width="1.5">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
      </svg>
    ))}
  </div>
  <blockquote class="flex-1 text-earth-800 leading-relaxed">
    <slot />
  </blockquote>
  <figcaption class="mt-5 flex items-center gap-3">
    <span class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-100 font-display font-semibold text-brand-700">
      {autor.charAt(0)}
    </span>
    <span class="text-sm font-semibold text-earth-900">{autor}</span>
  </figcaption>
</figure>
