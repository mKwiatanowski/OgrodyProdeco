---
interface Props {
  title?: string;
  subtitle?: string;
  ctaLabel?: string;
  ctaHref?: string;
}
const {
  title = "Masz pomysł na swój ogród? Porozmawiajmy o nim.",
  subtitle = "Bezpłatna wycena i rozmowa o możliwościach Twojej działki — bez zobowiązań.",
  ctaLabel = "Skontaktuj się z nami",
  ctaHref = "/kontakt",
} = Astro.props;
---

<section class="relative isolate overflow-hidden bg-brand-700">
  <!-- dekoracyjne liście w tle -->
  <svg class="absolute -left-16 -top-16 h-72 w-72 text-brand-600/60 -z-10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z" />
  </svg>
  <svg class="absolute -right-12 -bottom-20 h-80 w-80 rotate-180 text-brand-800/70 -z-10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z" />
  </svg>

  <div class="mx-auto max-w-4xl px-4 py-20 text-center">
    <h2 class="text-3xl md:text-4xl font-semibold text-white text-balance">{title}</h2>
    <p class="mt-4 text-lg text-brand-100">{subtitle}</p>
    <div class="mt-9 flex flex-wrap justify-center gap-4">
      <a
        href={ctaHref}
        class="rounded-full bg-white px-7 py-3.5 font-semibold text-brand-700 hover:bg-brand-50 transition-colors shadow-lg"
      >
        {ctaLabel}
      </a>
      <a
        href="tel:+48608354401"
        class="rounded-full border border-white/40 px-7 py-3.5 font-semibold text-white hover:bg-white/10 transition-colors"
      >
        Zadzwoń: 608 354 401
      </a>
    </div>
  </div>
</section>
