---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTASection from "../../components/CTASection.astro";
import Icon from "../../components/Icon.astro";
import { url } from "../../lib/url";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const uslugi = await getCollection("uslugi");
  return uslugi.map((usluga) => ({
    params: { slug: usluga.slug },
    props: { usluga },
  }));
}

const { usluga } = Astro.props;
const { Content } = await usluga.render();

const pozostale = (await getCollection("uslugi"))
  .filter((u) => u.slug !== usluga.slug)
  .sort((a, b) => a.data.kolejnosc - b.data.kolejnosc);
---

<BaseLayout title={usluga.data.title} description={usluga.data.skrot}>
  <section class="bg-brand-50 border-b border-brand-100">
    <div class="mx-auto max-w-6xl px-4 py-14 md:py-20">
      <nav class="mb-5 text-sm text-earth-600" aria-label="Okruszki">
        <a href={url("/oferta")} class="hover:text-brand-700">Oferta</a>
        <span class="mx-2" aria-hidden="true">/</span>
        <span class="text-earth-800">{usluga.data.title}</span>
      </nav>
      <div class="flex items-start gap-5">
        {usluga.data.ikona && (
          <span class="hidden sm:flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-brand-600 text-white">
            <Icon name={usluga.data.ikona} class="h-7 w-7" />
          </span>
        )}
        <div>
          <h1 class="text-3xl md:text-5xl font-semibold text-earth-900 text-balance">
            {usluga.data.title}
          </h1>
          <p class="mt-4 max-w-2xl text-lg text-earth-700">{usluga.data.skrot}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-14 grid gap-12 lg:grid-cols-[1fr_320px]">
    <article class="prose prose-lg prose-headings:font-display prose-a:text-brand-700 prose-li:marker:text-brand-500 max-w-none">
      <Content />
    </article>

    <aside class="space-y-6 lg:sticky lg:top-24 self-start">
      <div class="rounded-2xl bg-brand-700 p-7 text-white">
        <h2 class="font-display text-xl mb-2">Zapytaj o tę usługę</h2>
        <p class="text-sm text-brand-100 mb-5">
          Bezpłatna wycena — opisz działkę, odpowiemy w 1–2 dni robocze.
        </p>
        <a
          href={url("/kontakt")}
          class="block rounded-full bg-white px-5 py-2.5 text-center text-sm font-semibold text-brand-700 hover:bg-brand-50 transition-colors"
        >
          Napisz do nas
        </a>
        <a
          href="tel:+48608354401"
          class="mt-3 block rounded-full border border-white/40 px-5 py-2.5 text-center text-sm font-semibold text-white hover:bg-white/10 transition-colors"
        >
          608 354 401
        </a>
      </div>

      <div class="rounded-2xl border border-brand-100 p-7">
        <h2 class="font-display text-lg text-earth-900 mb-4">Pozostałe usługi</h2>
        <ul class="space-y-2.5 text-sm">
          {pozostale.map((u) => (
            <li>
              <a href={url(`/oferta/${u.slug}`)} class="flex items-center gap-2 text-earth-800 hover:text-brand-700 transition-colors">
                <Icon name="arrow-right" class="h-3.5 w-3.5 text-brand-400" />
                {u.data.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </aside>
  </section>

  <CTASection title={`Zainteresowany usługą „${usluga.data.title}”?`} />
</BaseLayout>
